BATCH_DIR=/media/plex/.downloads/torrent-batch
HOST=0.0.0.0
PORT=8787

# Google OAuth upload auth. Public IP HTTP redirects are not accepted by Google;
# set APP_ORIGIN to an HTTPS domain or tunnel URL configured on your OAuth client.
APP_ORIGIN=https://torplex.example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_COOKIE_SECRET=replace-with-a-long-random-secret
AUTH_ALLOWED_EMAILS=alex@hivetech.ai

# Comma-separated public IPs to suppress from the swarm map, such as your VM IP.
IGNORED_PEER_IPS=
