BATCH_DIR=/media/plex/.downloads/torrent-batch
HOST=0.0.0.0
PORT=8787

MEDIA_ROOT=/media/plex
MOVIES_DIR=/media/plex/Movies
TV_DIR="/media/plex/TV Shows"
DISK_USAGE_PATH=/media/plex

PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=
PLEX_PREFERENCES_PATH="/var/lib/plexmediaserver/Library/Application Support/Plex Media Server/Preferences.xml"
PLEX_MOVIE_SECTION_ID=1
PLEX_SHOW_SECTION_ID=2

MEDIA_CHOWN=
MEDIA_DIR_MODE=775
MEDIA_FILE_MODE=664

# Password auth. Keep AUTH_REQUIRED=true for internet-reachable installs.
APP_ORIGIN=https://torplex.example.com
AUTH_REQUIRED=true
AUTH_PASSWORD=replace-with-a-login-password
AUTH_COOKIE_SECRET=replace-with-a-long-random-secret

# Comma-separated public IPs to suppress from the swarm map, such as your VM IP.
IGNORED_PEER_IPS=
